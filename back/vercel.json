{
    "version": 2,
    "builds": [
        {
            "src": "server.js",
            "use": "@vercel/node"
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "server.js"
        }
    ],
    "files": {
        "include": ["back/config/DigiCertGlobalRootCA.crt.pem"]
    }
}